[resource]
script = ExtResource("1_table")
LootTableId = "weapon_case_loot_table"
DisplayName = "Weapon Case Loot Table"
MinRollCount = 2
MaxRollCount = 3
RarityWeights = Array[ExtResource("4_rarity_weight")]([SubResource("LootRarityWeight_green"), SubResource("LootRarityWeight_blue"), SubResource("LootRarityWeight_purple"), SubResource("LootRarityWeight_gold")])
CategoryWeights = Array[ExtResource("5_category_weight")]([SubResource("LootCategoryWeight_weapon"), SubResource("LootCategoryWeight_gloves"), SubResource("LootCategoryWeight_skill")])
Buckets = Array[ExtResource("3_bucket")]([SubResource("LootBucket_green_weapon"), SubResource("LootBucket_green_gloves"), SubResource("LootBucket_blue_skill"), SubResource("LootBucket_blue_weapon")])
